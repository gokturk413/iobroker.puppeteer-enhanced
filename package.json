{
  "name": "iobroker.puppeteer-enhanced",
  "version": "0.5.0",
  "description": "Headless browser to generate screenshots and PDF exports based on Chrome",
  "author": {
    "name": "gokturk413",
    "email": "gokturk413@gmail.com"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/gokturk413/ioBroker.puppeteer-enhanced",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "screenshots",
    "visualization",
    "browser",
    "pdf",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gokturk413/ioBroker.puppeteer-enhanced.git"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "puppeteer": "^24.3.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.3.0",
    "@iobroker/types": "^7.2.2",
    "@tsconfig/node20": "^20.1.4",
    "@types/chai": "^4.3.16",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "@types/proxyquire": "^1.3.31",
    "@types/puppeteer": "^7.0.4",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^3.2.12",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "mocha": "^10.8.2",
    "prettier": "^3.9.5",
    "proxyquire": "^2.1.3",
    "rimraf": "^5.0.10",
    "sinon": "^17.0.1",
    "sinon-chai": "^3.7.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.64.0"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script -p iobroker"
  },
  "bugs": {
    "url": "https://github.com/gokturk413/ioBroker.puppeteer-enhanced/issues"
  },
  "readmeFilename": "README.md"
}
