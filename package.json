{
    "name": "iobroker.puppeteer-enhanced",
    "version": "0.5.2",
    "description": "Headless browser to generate screenshots and PDF exports based on Chrome",
    "author": {
        "name": "gokturk413",
        "email": "gokturk413@gmail.com"
    },
    "engines": {
        "node": ">=20"
    },
    "homepage": "https://github.com/gokturk413/ioBroker.puppeteer-enhanced",
    "license": "MIT",
    "keywords": [
        "ioBroker",
        "screenshots",
        "visualization",
        "browser",
        "pdf",
        "export"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gokturk413/ioBroker.puppeteer-enhanced.git"
    },
    "dependencies": {
        "@iobroker/adapter-core": "^3.4.3",
        "puppeteer": "^24.43.1"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/eslint-config": "^2.3.4",
        "@iobroker/testing": "^5.3.0",
        "@iobroker/types": "^7.2.2",
        "@tsconfig/node20": "^20.1.9",
        "@types/node": "^20.17.0",
        "rimraf": "^5.0.10",
        "typescript": "^6.0.3"
    },
    "main": "build/main.js",
    "files": [
        "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
        "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
        "build/",
        "www/",
        "io-package.json",
        "LICENSE"
    ],
    "scripts": {
        "prebuild": "rimraf build",
        "build": "build-adapter ts",
        "watch": "build-adapter ts --watch",
        "prebuild:ts": "rimraf build",
        "build:ts": "build-adapter ts",
        "watch:ts": "build-adapter ts --watch",
        "test:package": "mocha test/package --exit",
        "test:integration": "mocha test/integration --exit",
        "test:unit": "mocha --config test/mocharc.unit.json",
        "test": "npm run test:unit && npm run test:package",
        "check": "tsc --noEmit",
        "lint": "eslint .",
        "translate": "translate-adapter",
        "release": "release-script -p iobroker"
    },
    "bugs": {
        "url": "https://github.com/gokturk413/ioBroker.puppeteer-enhanced/issues"
    },
    "readmeFilename": "README.md"
}
