{
  "type": "panel",
  "i18n": true,
  "items": {
    "useExternalBrowser": {
      "type": "checkbox",
      "label": "useExternalBrowser",
      "xs": 12,
      "sm": 12,
      "md": 6
    },
    "executablePath": {
      "placeholder": "/usr/bin/chromium-browser",
      "hidden": "!data.useExternalBrowser",
      "newLine": true,
      "type": "text",
      "label": "executablePath",
      "xs": 12,
      "sm": 12,
      "md": 6
    },
    "additionalArgs": {
      "newLine": true,
      "label": "additionalLaunchArgs",
      "type": "table",
      "uniqueColumns": ["Argument"],
      "xs": 12,
      "items": [{
        "attr": "Argument",
        "label": "Argument",
        "filter": false,
        "sort": false,
        "type": "autocomplete",
        "freeSolo": true,
        "options": [
          "--disable-lcd-text",
          "--disable-composited-antialiasing"
        ]
      }]
    },
    "_performanceHeader": {
      "newLine": true,
      "type": "header",
      "text": "performanceSettings",
      "size": 5,
      "xs": 12
    },
    "maxParallelProcesses": {
      "newLine": true,
      "type": "number",
      "min": 1,
      "max": 20,
      "step": 1,
      "label": "maxParallelProcesses",
      "help": "maxParallelProcessesHelp",
      "xs": 12,
      "sm": 6,
      "md": 4
    },
    "_webExtensionHeader": {
      "newLine": true,
      "type": "header",
      "text": "webExtensionSettings",
      "size": 5,
      "xs": 12
    },
    "_webExtensionHint": {
      "newLine": true,
      "type": "staticText",
      "text": "webExtensionHint",
      "xs": 12
    },
    "webInstance": {
      "newLine": true,
      "type": "instance",
      "adapter": "web",
      "all": true,
      "allText": "allWebInstances",
      "label": "webInstance",
      "help": "webInstanceHelp",
      "xs": 12,
      "sm": 12,
      "md": 6
    },
    "_webLoginHeader": {
      "newLine": true,
      "type": "header",
      "text": "webLoginCredentials",
      "size": 5,
      "xs": 12
    },
    "webUsername": {
      "newLine": true,
      "type": "text",
      "label": "webUsername",
      "placeholder": "admin",
      "xs": 12,
      "sm": 6
    },
    "webPassword": {
      "newLine": true,
      "type": "password",
      "label": "webPassword",
      "visible": true,
      "repeat": false,
      "xs": 12,
      "sm": 6
    }
  }
}