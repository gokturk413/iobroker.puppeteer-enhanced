{
  "type": "panel",
  "i18n": true,
  "items": {
    "useExternalBrowser": {
      "type": "checkbox",
      "label": "useExternalBrowser",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "executablePath": {
      "placeholder": "/usr/bin/chromium-browser",
      "hidden": "!data.useExternalBrowser",
      "newLine": true,
      "type": "text",
      "label": "executablePath",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "additionalArgs": {
      "newLine": true,
      "label": "additionalLaunchArgs",
      "type": "table",
      "uniqueColumns": ["Argument"],
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "items": [{
        "attr": "Argument",
        "label": "Argument",
        "filter": false,
        "sort": false,
        "type": "autocomplete",
        "freeSolo": true,
        "options": [
          "--disable-lcd-text",
          "--disable-composited-antialiasing"
        ]
      }]
    },
    "_webLoginHeader": {
      "newLine": true,
      "type": "header",
      "text": "webLoginCredentials",
      "size": 5,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    },
    "webUsername": {
      "newLine": true,
      "type": "text",
      "label": "webUsername",
      "placeholder": "admin",
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "webPassword": {
      "newLine": true,
      "type": "password",
      "label": "webPassword",
      "visible": true,
      "repeat": false,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 6,
      "xl": 6
    }
  }
}